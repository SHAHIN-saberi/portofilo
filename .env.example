# ============================================================
# Personal AI Resume/Portfolio — Environment Template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ============================================================

# ---- Database ----
# Used by docker-compose to init the Postgres (pgvector) container
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=portfolio

# ---- Backend (FastAPI) ----
# Async driver for SQLAlchemy. Host is the compose service name.
DATABASE_URL=postgresql+asyncpg://portfolio:change-me-strong-password@postgres:5432/portfolio

# ---- AI Provider ----
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=text-embedding-004
EMBEDDING_DIM=768

# Optional fallback provider (DeepSeek)
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_CHAT_MODEL=deepseek-chat
# DEEPSEEK_EMBED_MODEL=deepseek-embed

# ---- Admin (single admin) ----
ADMIN_EMAIL=owner@example.com
# bcrypt hash of the admin password (generate with scripts/gen_password_hash.py)
ADMIN_PASSWORD_HASH=
# Secret for signing admin session tokens (JWT)
AUTH_SECRET=change-me-to-a-long-random-string
AUTH_TOKEN_TTL_MINUTES=720

# ---- CORS / URLs ----
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=

# ---- Chatbot / RAG tuning ----
RAG_TOP_K=6
RAG_SIMILARITY_THRESHOLD=0.65
CHAT_RATE_LIMIT_PER_5MIN=20
CHAT_MAX_TURNS=10
